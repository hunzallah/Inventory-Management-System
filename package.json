{
  "name": "inventory-management-system",
  "version": "1.0.0",
  "homepage": "./",
  "description": "Simple Desktop Inventory Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run react\" \"wait-on http://localhost:3000 && npm run electron\"",
    "server": "nodemon server/index.js",
    "react": "react-scripts start",
    "electron": "electron .",
    "build": "react-scripts build && electron-builder",
    "postbuild": "npm rebuild better-sqlite3",
    "start": "react-scripts build && electron ."
  },
  "build": {
    "appId": "com.ims.app",
    "productName": "Inventory Management System",
    "extends": null,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "build/**/*",
      "electron/**/*",
      "server/**/*",
      "database/db.js",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.7",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.1",
    "react-scripts": "^5.0.1",
    "react-to-print": "^2.15.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.18",
    "tailwindcss": "^3.4.19",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}